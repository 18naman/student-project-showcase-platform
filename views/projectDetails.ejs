<%- include("partials/navbar") %>

<div class="container mt-4">

<h3><%=project.title%></h3>

<img src="/uploads/<%=project.image%>" width="300">

<p><%=project.description%></p>

<% if(project.link){ %>

<a href="<%=project.link%>" class="btn btn-primary">

Github

</a>

<% } %>

<p>

❤️ <%=project.likes%>

</p>



<% if(student){ %>

<form method="POST" action="/project/like/<%=project._id%>">

<button class="btn btn-danger">

Like

</button>

</form>



<hr>

<h4>Comments</h4>



<% comments.forEach(c=>{ %>

<p>

<b><%=c.userEmail%></b> :

<%=c.text%>

</p>

<% }) %>



<form method="POST" action="/project/comment/<%=project._id%>">

<input name="text" class="form-control mb-2">

<button class="btn btn-success">

Comment

</button>

</form>

<% } %>

</div>