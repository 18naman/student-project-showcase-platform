<%- include("partials/navbar") %>

<div class="container mt-4">

<h3>Admin Dashboard</h3>

<h4>Projects</h4>

<table class="table">

<tr>

<th>Title</th>

<th>Status</th>

<th>Approve</th>

<th>Reject</th>

</tr>

<% projects.forEach(p=>{ %>

<tr>

<td><%=p.title%></td>

<td>

<%=p.status%>

</td>

<td>

<% if(p.status=="pending"){ %>

<form method="POST" action="/admin/approve/<%=p._id%>">

<button class="btn btn-success btn-sm">

Approve

</button>

</form>

<% } %>

</td>

<td>

<% if(p.status=="pending"){ %>

<form method="POST" action="/admin/reject/<%=p._id%>">

<button class="btn btn-danger btn-sm">

Reject

</button>

</form>

<% } %>

</td>

</tr>

<% }) %>

</table>

</div>