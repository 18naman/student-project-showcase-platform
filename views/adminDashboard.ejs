<%- include("partials/navbar") %>

<div class="container">

<h1 class="mb-5">
Admin Dashboard
</h1>

<div class="card p-4 mb-5">

<h3 class="mb-4">
Projects
</h3>

<div class="table-responsive">

<table class="table align-middle">

<tr>

<th>Title</th>
<th>Status</th>
<th>Actions</th>

</tr>

<% projects.forEach(p=>{ %>

<tr>

<td>
<%=p.title%>
</td>

<td>

<% if(p.status=="pending"){ %>

<span class="badge bg-warning text-dark">
Pending
</span>

<% } %>

<% if(p.status=="approved"){ %>

<span class="badge bg-success">
Approved
</span>

<% } %>

<% if(p.status=="rejected"){ %>

<span class="badge bg-danger">
Rejected
</span>

<% } %>

</td>

<td class="d-flex gap-2">

<a 
href="/admin/view/<%=p._id%>"
class="btn btn-primary btn-sm"
>
View
</a>

</td>

</tr>

<% }) %>

</table>

</div>

</div>

<div class="card p-4">

<h3 class="mb-4">
Students
</h3>

<div class="table-responsive">

<table class="table align-middle">

<tr>

<th>Name</th>
<th>Email</th>
<th>Delete</th>

</tr>

<% students.forEach(s=>{ %>

<tr>

<td>
<%=s.name%>
</td>

<td>
<%=s.email%>
</td>

<td>

<form 
method="POST"
action="/admin/deleteStudent/<%=s._id%>"
>

<button class="btn btn-danger btn-sm">
Delete
</button>

</form>

</td>

</tr>

<% }) %>

</table>

</div>

</div>

</div>