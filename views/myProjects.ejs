<%- include("partials/navbar") %>

<div class="container mt-4">

<h3>My Projects</h3>

<div class="row">

<% projects.forEach(p=>{ %>

<div class="col-md-4">

<div class="card shadow p-3 mb-3">

<h5><%=p.title%></h5>

<img src="/uploads/<%=p.image%>" class="img-fluid mb-2">

<p>

<%=p.description%>

</p>


<p>

Status:

<% if(p.status=="pending"){ %>

<span class="badge bg-warning">

Waiting for admin approval

</span>

<% } %>


<% if(p.status=="approved"){ %>

<span class="badge bg-success">

Approved

</span>

<div class="alert alert-success mt-2">

<%=p.adminMessage%>

</div>

<% } %>


<% if(p.status=="rejected"){ %>

<span class="badge bg-danger">

Rejected

</span>

<div class="alert alert-danger mt-2">

Reason:

<%=p.adminMessage%>

</div>

<% } %>

</p>


<a href="/project/edit/<%=p._id%>" class="btn btn-warning btn-sm">

Edit

</a>


<form method="POST" action="/project/delete/<%=p._id%>">

<button class="btn btn-danger btn-sm mt-2">

Delete

</button>

</form>

</div>

</div>

<% }) %>

</div>

</div>