<%- include("partials/navbar") %>

<div class="container">

<div class="text-center mb-5">

<h1 class="display-3 fw-bold glow-text">
🚀 Student Project Showcase
</h1>

<p class="text-light">
Explore innovative student projects
</p>

<form class="mb-5">

<select
name="category"
class="form-control"
onchange="this.form.submit()"
>

<option value="">
All Categories
</option>

<option value="Web Development">
Web Development
</option>

<option value="AI/ML">
AI/ML
</option>

<option value="IoT">
IoT
</option>

<option value="Mobile App">
Mobile App
</option>

<option value="Cyber Security">
Cyber Security
</option>

<option value="Blockchain">
Blockchain
</option>

<option value="Cloud Computing">
Cloud Computing
</option>

</select>

</form>

</div>

<div class="row">

<% if(projects.length === 0){ %>

<div class="text-center mt-5">

<h3>
No Projects Available Yet
</h3>

<p class="text-light">
Projects approved by admin will appear here.
</p>

</div>

<% } %>

<% projects.forEach(p=>{ %>

<div class="col-md-4 mb-4">

<div class="card h-100 shadow-lg">

<img 
src="/uploads/<%=p.image%>" 
class="project-img"
>

<div class="card-body">

<h4 class="mb-3">

<%=p.title%>

</h4>

<span class="badge bg-info mb-3">
<%=p.category%>
</span>

<p>

<%=p.description.substring(0,120)%>...

</p>

<div class="d-flex justify-content-between align-items-center mt-3">

<span>
❤️ <%=p.likes%>
</span>

<a 
href="/project/details/<%=p._id%>" 
class="btn btn-primary"
>
View
</a>

</div>

<% if(p.link){ %>

<a 
href="<%=p.link%>" 
target="_blank"
class="btn btn-dark w-100 mt-3"
>
View GitHub
</a>

<% } %>

</div>

</div>

</div>

<% }) %>

</div>

</div>