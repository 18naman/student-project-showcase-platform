<%- include("partials/navbar") %>

<div class="container mt-4">

<h3>

<%=project.title%>

</h3>

<img src="/uploads/<%=project.image%>" width="300" class="mb-3">

<p>

<%=project.description%>

</p>


<% if(project.link){ %>

<a href="<%=project.link%>" class="btn btn-primary">

GitHub

</a>

<% } %>


<hr>

<h4>Comments</h4>

<% comments.forEach(c=>{ %>

<p>

<b><%=c.userEmail%></b> :

<%=c.text%>

</p>

<% }) %>


<hr>

<h4>Admin Action</h4>


<form method="POST" action="/admin/approve/<%=project._id%>">

<button class="btn btn-success">

Approve

</button>

</form>


<br>


<form method="POST" action="/admin/reject/<%=project._id%>">

<label>

Reason for rejection

</label>

<textarea
name="message"
class="form-control mb-2"
placeholder="Write reason for rejection"
required
></textarea>

<button class="btn btn-danger">

Reject

</button>

</form>

</div>