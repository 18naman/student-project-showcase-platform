<%- include("partials/navbar") %>

<div class="container">

<div class="card p-5 shadow-lg">

<img 
src="/uploads/<%=project.image%>"
class="project-img rounded mb-4"
>

<h1 class="mb-3">
<%=project.title%>
</h1>

<p class="mb-4">
<%=project.description%>
</p>

<% if(project.link){ %>

<a 
href="<%=project.link%>"
target="_blank"
class="btn btn-dark mb-4"
>
View GitHub
</a>

<% } %>

<hr class="my-4">

<h3 class="mb-4">
Comments
</h3>

<% comments.forEach(c=>{ %>

<div class="card p-3 mb-3">

<b class="text-info">
<%=c.userEmail%>
</b>

<p class="mt-2 mb-0">
<%=c.text%>
</p>

</div>

<% }) %>

<hr class="my-4">

<div class="d-flex gap-3 mb-4">

<form 
method="POST"
action="/admin/approve/<%=project._id%>"
>

<button class="btn btn-success">
Approve
</button>

</form>

</div>

<form 
method="POST"
action="/admin/reject/<%=project._id%>"
>

<label class="mb-2">
Reason for rejection
</label>

<textarea
name="message"
class="form-control mb-3"
placeholder="Write rejection reason"
required
></textarea>

<button class="btn btn-danger">
Reject
</button>

</form>

</div>

</div>